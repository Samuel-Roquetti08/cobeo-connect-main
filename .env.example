# ============================================================================
# COBEO CONNECT — Variáveis de Ambiente (EXEMPLO)
# ============================================================================
# Copie este arquivo para .env e preencha com os valores reais.
# O .env NUNCA deve ser commitado (já está no .gitignore).
# ============================================================================

# ─── Supabase (PÚBLICAS — vão para o browser, protegidas por RLS) ───────────
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ─── Supabase (SECRETA — apenas servidor / Edge Functions) ──────────────────
# NÃO use o prefixo VITE_ aqui — isso a manteria fora do bundle do browser.
# Esta vai apenas nas variáveis de ambiente do Cloudflare e nas Edge Functions.
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ─── Mercado Pago (SECRETAS — apenas servidor) ──────────────────────────────
MP_ACCESS_TOKEN=TEST-xxxx-aguardando-fabiano
MP_PUBLIC_KEY=TEST-xxxx-aguardando-fabiano

# ─── Resend (e-mail transacional — apenas servidor) ─────────────────────────
RESEND_API_KEY=re_xxxx-aguardando
